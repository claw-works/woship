# 使用前先创建 secret:
# kubectl create secret generic woship-backend-secrets -n woship \
#   --from-literal=DB_HOST=<rds-endpoint> \
#   --from-literal=DB_PORT=5432 \
#   --from-literal=DB_USER=woship \
#   --from-literal=DB_PASSWORD=<password> \
#   --from-literal=DB_NAME=woship \
#   --from-literal=DB_SSLMODE=require \
#   --from-literal=JWT_SECRET=<your-jwt-secret>
apiVersion: v1
kind: Secret
metadata:
  name: woship-backend-secrets
  namespace: woship
type: Opaque
stringData:
  DB_HOST: "CHANGE_ME"
  DB_PORT: "5432"
  DB_USER: "woship"
  DB_PASSWORD: "CHANGE_ME"
  DB_NAME: "woship"
  DB_SSLMODE: "require"
  JWT_SECRET: "CHANGE_ME"
